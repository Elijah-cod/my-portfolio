<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description }}" />
    <meta name="theme-color" content="#f7f5ff" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content="{{ title }} | Elijah Mathai" />
    <meta property="og:description" content="{{ description }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:image" content="{{ site.url }}{{ image }}" />
    <meta property="article:published_time" content="{{ date | isoDate }}" />
    <meta property="article:author" content="Elijah Mathai" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="{{ site.url }}{{ image }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    <link rel="icon" type="image/png" href="/assets/elijah-mathai-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@400;500;600&family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <title>{{ title }} | Elijah Mathai</title>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {{ title | json | safe }},
        "description": {{ description | json | safe }},
        "image": "{{ site.url }}{{ image }}",
        "datePublished": "{{ date | isoDate }}",
        "author": { "@type": "Person", "name": "Elijah Mathai" },
        "mainEntityOfPage": "{{ site.url }}{{ page.url }}"
      }
    </script>
  </head>
  <body class="article-page">
    <a class="skip-link" href="#article">Skip to article</a>
    <header class="site-header" data-header>
      <a class="brand" href="/" aria-label="Elijah Mathai, home">
        <span class="brand-mark"><img src="/assets/elijah-mathai-logo.png" alt="" width="44" height="44" /></span>
        <span class="brand-name">Elijah Mathai</span>
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation" data-menu-toggle>
        <span>Menu</span><span class="menu-lines" aria-hidden="true"></span>
      </button>
      <nav class="site-nav" id="primary-navigation" aria-label="Primary" data-menu>
        <a href="/#work">Work</a><a href="/#approach">Approach</a><a href="/#story">Story</a><a href="/articles/">Articles</a><a class="nav-cta" href="/#contact">Let’s talk</a>
      </nav>
    </header>

    <main class="subpage-main" id="article">
      <header class="article-hero page-width" data-reveal>
        <p class="eyebrow">{{ category }} · {{ readTime }}</p>
        <h1>{{ title }}</h1>
        <p class="article-dek">{{ excerpt }}</p>
      </header>

      <figure class="article-cover page-width" data-reveal>
        <img src="{{ image }}" alt="{{ imageAlt }}" width="1440" height="900" />
      </figure>

      <div class="page-width article-layout">
        <article class="article-body">{{ content | safe }}
          {% if projectUrl %}
            <div class="article-end"><p><strong>Related build:</strong> <a class="text-link" href="{{ projectUrl }}" target="_blank" rel="noreferrer">{{ projectLabel or "Open the live project" }} ↗</a></p></div>
          {% endif %}
        </article>
        <aside class="article-aside" aria-label="Article details">
          <div><p>Written by</p><strong>Elijah Mathai</strong></div>
          <div><p>Published</p><time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time></div>
          <div><p>Filed under</p><strong>{{ category }}</strong></div>
          <div><p>Manage</p><a class="text-link" href="/admin/#/collections/articles" rel="nofollow">Article studio</a></div>
        </aside>
      </div>
    </main>

    <footer class="site-footer"><div class="page-width footer-grid"><div class="footer-brand"><img src="/assets/elijah-mathai-logo.png" alt="" width="40" height="40" /><strong>Elijah Mathai</strong></div><p>© <span data-year>2026</span> Elijah Mathai. All rights reserved.</p><div class="footer-links"><a href="/articles/">All articles</a><a href="/#contact">Contact</a><a href="/">Home</a></div></div></footer>
    <script src="/script.js"></script>
  </body>
</html>
